APP_ENV=development
HOST=0.0.0.0
PORT=3000
RP_NAME=Passless
RP_ID=localhost
EXPECTED_ORIGIN=http://localhost:3000
# Optional comma-separated additional origins (e.g. https://app.example.com,https://admin.example.com)
# EXPECTED_ORIGINS=
# Allow Cloudflare quick tunnel hostnames that match TRYCLOUDFLARE_ORIGIN_PATTERN
ALLOW_TRYCLOUDFLARE_ORIGIN=false
TRYCLOUDFLARE_ORIGIN_PATTERN=^https://[a-z0-9-]+\.trycloudflare\.com$
# Allow ngrok hostnames that match NGROK_ORIGIN_PATTERN
ALLOW_NGROK_ORIGIN=false
NGROK_ORIGIN_PATTERN=^https://[a-z0-9-]+\.(?:ngrok-free\.app|ngrok\.io|ngrok\.app)$
SESSION_SECRET=replace-with-very-long-random-value
DB_PATH=./data/passless.db
CHALLENGE_TTL_SECONDS=300
HTTPS_ENABLED=false
# HTTPS_KEY_PATH=./certs/key.pem
# HTTPS_CERT_PATH=./certs/cert.pem
