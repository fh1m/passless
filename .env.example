# Passless Configuration
# Generated from: cp .env.example .env
# After changes, restart: python -m src.server

# App environment: development, test, production
APP_ENV=development

# Server binding
HOST=0.0.0.0
PORT=3000

# WebAuthn Relying Party configuration
RP_NAME=Passless
# For localhost: use "localhost"
# For tunnel: use tunnel hostname (e.g., passless.trycloudflare.com)
# For production: use your domain (e.g., passless.example.com)
RP_ID=localhost

# Expected origin (must match browser URL scheme://host:port)
# For localhost HTTP: http://localhost:3000
# For localhost HTTPS: https://localhost:3000 (requires HTTPS_ENABLED=true)
# For tunnel: https://xyz.trycloudflare.com (requires ALLOW_TRYCLOUDFLARE_ORIGIN=true)
EXPECTED_ORIGIN=http://localhost:3000

# Optional comma-separated additional allowed origins
# EXPECTED_ORIGINS=https://app.example.com,https://admin.example.com

# === TUNNEL CONFIGURATION ===
# For temporary cross-device testing with: cloudflared tunnel --url http://localhost:3000
# Set this to true to accept any https://xyz.trycloudflare.com origin
# WARNING: Only enable for development. Disable before production.
ALLOW_TRYCLOUDFLARE_ORIGIN=false

# Regex pattern for accepted Cloudflare tunnel hostnames
TRYCLOUDFLARE_ORIGIN_PATTERN=^https://[a-z0-9-]+\.trycloudflare\.com$

# For ngrok tunnels: ngrok http 3000
ALLOW_NGROK_ORIGIN=false
NGROK_ORIGIN_PATTERN=^https://[a-z0-9-]+\.(?:ngrok-free\.app|ngrok\.io|ngrok\.app)$

# === SESSION SECURITY ===
# Must be at least 16 characters. Change before production!
SESSION_SECRET=replace-with-very-long-random-value

# === DATABASE ===
DB_PATH=./data/passless.db

# WebAuthn challenge lifetime (seconds)
CHALLENGE_TTL_SECONDS=300

# === HTTPS (optional) ===
# For localhost development with self-signed cert:
# 1. openssl req -x509 -newkey rsa:2048 -nodes -keyout certs/key.pem -out certs/cert.pem -days 365 -subj "/CN=localhost"
# 2. Set HTTPS_ENABLED=true and uncomment paths below
# 3. Change EXPECTED_ORIGIN=https://localhost:3000
# 4. Restart with: python -m src.server
HTTPS_ENABLED=false
# HTTPS_KEY_PATH=./certs/key.pem
# HTTPS_CERT_PATH=./certs/cert.pem
